# Copy this file to .env and fill in the values you need.
# These names match the SDKs' expected environment variables, so the
# adapters work without extra wiring.

# --- Backend storage ---
# Where the SQLite database, audio files, and uploads live. Default in
# Docker is /app/data; locally use ../data so it sits next to the repo.
APP_DATA_DIR=../data

# --- LLM providers (only set the ones you intend to use) ---
ANTHROPIC_API_KEY=

# Task 4 will start using these:
GOOGLE_API_KEY=
OPENAI_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- Speech providers (Task 5+) ---
# Path to a Google service account JSON file with Speech-to-Text and
# Text-to-Speech enabled.
GOOGLE_APPLICATION_CREDENTIALS=
