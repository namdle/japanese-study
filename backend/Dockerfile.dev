# Dev image for the FastAPI backend with hot reload.
# Production single-container image is built from the repo-root Dockerfile in Task 15.
FROM python:3.12-slim

WORKDIR /app

# System deps: gcc not strictly required for our pure-Python deps, but kept
# minimal. Adding curl for healthchecks and debugging.
RUN apt-get update \
    && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

# Install Python deps first for better layer caching.
COPY pyproject.toml ./
RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -e .[dev]

COPY app ./app
COPY tests ./tests

EXPOSE 8000

# Hot reload via uvicorn --reload. The source is bind-mounted in dev compose.
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
